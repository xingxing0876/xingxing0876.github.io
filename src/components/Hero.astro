---
import { profile } from '../data/resume';

const base = import.meta.env.BASE_URL;
---

<section class="hero">
	<div class="container hero-inner">
		<img
			src={`${base}${profile.avatar}`}
			alt={`${profile.name} 的头像`}
			class="avatar"
			width="140"
			height="196"
		/>
		<div class="hero-text">
			<p class="eyebrow">你好，我是</p>
			<h1 class="name">{profile.name}</h1>
			<p class="title">{profile.title}</p>
			<p class="tagline">{profile.tagline}</p>
			<p class="meta">
				{profile.location} · {profile.experienceYears} 年经验 · {profile.email}
			</p>
			<div class="hero-actions">
				<a href={`${base}projects`} class="btn btn-primary">浏览作品</a>
			</div>
		</div>
	</div>
</section>

<style>
	.hero {
		padding: 4rem 0 2rem;
	}

	.hero-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.5rem;
	}

	.avatar {
		width: 140px;
		height: auto;
		aspect-ratio: 277 / 389;
		border-radius: 12px;
		border: 4px solid var(--color-surface);
		box-shadow: var(--shadow);
		object-fit: contain;
		background: #fff;
		flex-shrink: 0;
	}

	.eyebrow {
		margin: 0 0 0.25rem;
		color: var(--color-text-muted);
		font-size: 0.95rem;
	}

	.name {
		margin: 0;
		font-size: clamp(2rem, 5vw, 2.75rem);
		font-weight: 700;
		letter-spacing: -0.03em;
	}

	.title {
		margin: 0.25rem 0 0;
		font-size: 1.15rem;
		color: var(--color-accent);
		font-weight: 600;
	}

	.tagline {
		margin: 0.75rem 0 0;
		color: var(--color-text-muted);
	}

	.meta {
		margin: 0.5rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.95rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.75rem;
		margin-top: 1.5rem;
	}

	@media (min-width: 768px) {
		.hero-inner {
			flex-direction: row;
			text-align: left;
		}

		.hero-actions {
			justify-content: flex-start;
		}
	}
</style>
