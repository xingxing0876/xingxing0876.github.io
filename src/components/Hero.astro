---
import { profile, experience } from '../data/resume';

interface Props {
	projectCount: number;
}

const { projectCount } = Astro.props;
const base = import.meta.env.BASE_URL;

const stats = [
	{ value: `${profile.experienceYears}`, suffix: '年', label: '从业经验' },
	{ value: `${experience.length}`, suffix: '段', label: '工作经历' },
	{ value: `${projectCount}`, suffix: '个', label: '项目案例' },
	{ value: 'FinTech', suffix: '', label: '专注领域' },
];
---

<section class="hero">
	<div class="hero-bg" aria-hidden="true"></div>
	<div class="container hero-content">
		<div class="hero-inner animate-fade-up">
			<div class="avatar-wrap">
				<img
					src={`${base}${profile.avatar}`}
					alt={`${profile.name} 的头像`}
					class="avatar"
					width="148"
					height="148"
				/>
			</div>
			<div class="hero-text">
				<p class="eyebrow">你好，我是</p>
				<h1 class="name">{profile.name}</h1>
				<p class="title">{profile.title}</p>
				<p class="tagline">{profile.tagline}</p>
				<p class="meta">
					{profile.location} · {profile.experienceYears} 年经验 · {profile.email}
				</p>
				<div class="hero-actions">
					<a href={`${base}projects`} class="btn btn-primary">浏览作品</a>
					<a href={profile.github} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
						GitHub
					</a>
				</div>
			</div>
		</div>

		<div class="stats-bar animate-fade-up" style="animation-delay: 0.15s">
			{
				stats.map((stat) => (
					<div class="stat-item">
						<p class="stat-value">
							{stat.value}
							{stat.suffix && <span class="stat-suffix">{stat.suffix}</span>}
						</p>
						<p class="stat-label">{stat.label}</p>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.hero {
		position: relative;
		padding: 5rem 0 3.5rem;
		overflow: hidden;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 70% 55% at 75% 0%, var(--color-hero-glow-1), transparent),
			radial-gradient(ellipse 50% 45% at 5% 90%, var(--color-hero-glow-2), transparent),
			linear-gradient(180deg, var(--color-hero-top) 0%, var(--color-bg) 100%);
		z-index: 0;
	}

	.hero-content {
		position: relative;
		z-index: 1;
	}

	.hero-inner {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 1.75rem;
	}

	.avatar-wrap {
		padding: 4px;
		border-radius: 50%;
		background: linear-gradient(135deg, var(--color-avatar-border-start), var(--color-avatar-border-end));
		box-shadow: var(--shadow-md);
		flex-shrink: 0;
		overflow: hidden;
	}

	.avatar {
		width: 148px;
		height: 148px;
		border-radius: 50%;
		object-fit: cover;
		object-position: center -350%;
		transform: scale(0.9);
		background: #fff;
		display: block;
	}

	.eyebrow {
		margin: 0 0 0.25rem;
		color: var(--color-text-muted);
		font-size: 0.95rem;
	}

	.name {
		margin: 0;
		font-size: clamp(2.25rem, 5vw, 3rem);
		font-weight: 700;
		letter-spacing: -0.04em;
		line-height: 1.1;
	}

	.title {
		margin: 0.5rem 0 0;
		font-size: 1.2rem;
		color: var(--color-accent);
		font-weight: 600;
	}

	.tagline {
		margin: 0.85rem 0 0;
		color: var(--color-text-muted);
		font-size: 1.05rem;
		max-width: 36rem;
	}

	.meta {
		margin: 0.6rem 0 0;
		color: var(--color-text-muted);
		font-size: 0.9rem;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.75rem;
		margin-top: 1.75rem;
	}

	.stats-bar {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		margin-top: 3rem;
		padding: 1.5rem 1.25rem;
		background: var(--color-stats-bg);
		backdrop-filter: blur(8px);
		border: 1px solid var(--color-border);
		border-radius: var(--radius-lg);
		box-shadow: var(--shadow-md);
		transition: background 0.25s;
	}

	.stat-item {
		text-align: center;
		padding: 0.5rem;
	}

	.stat-value {
		margin: 0;
		font-size: 1.5rem;
		font-weight: 700;
		letter-spacing: -0.03em;
		color: var(--color-text);
	}

	.stat-suffix {
		font-size: 0.95rem;
		font-weight: 600;
		color: var(--color-text-muted);
		margin-left: 0.1rem;
	}

	.stat-label {
		margin: 0.25rem 0 0;
		font-size: 0.85rem;
		color: var(--color-text-muted);
	}

	@media (min-width: 768px) {
		.hero-inner {
			flex-direction: row;
			text-align: left;
			align-items: center;
		}

		.hero-actions {
			justify-content: flex-start;
		}

		.stats-bar {
			grid-template-columns: repeat(4, 1fr);
			padding: 1.75rem 2rem;
		}

		.stat-item {
			position: relative;
		}

		.stat-item:not(:last-child)::after {
			content: '';
			position: absolute;
			right: 0;
			top: 50%;
			transform: translateY(-50%);
			width: 1px;
			height: 2.5rem;
			background: var(--color-border);
		}
	}
</style>
