---
interface Props {
	title: string;
	eyebrow?: string;
	items: Array<{
		primary: string;
		secondary?: string;
		period?: string;
		highlights?: string[];
	}>;
}

const { title, eyebrow = 'Experience', items } = Astro.props;
---

<section class="resume-section">
	<p class="section-eyebrow">{eyebrow}</p>
	<h2 class="section-title">{title}</h2>
	<div class="timeline">
		<div class="timeline-line" aria-hidden="true"></div>
		{
			items.map((item, index) => (
				<div class:list={['timeline-item', { 'is-latest': index === 0 }]}>
					<div class="timeline-marker" aria-hidden="true">
						<span class="timeline-dot" />
					</div>
					<div class="timeline-content card">
						<div class="timeline-header">
							<div>
								<h3 class="item-primary">{item.primary}</h3>
								{item.secondary && <p class="item-secondary">{item.secondary}</p>}
							</div>
							{item.period && <span class="item-period">{item.period}</span>}
						</div>
						{item.highlights && (
							<ul class="highlights">
								{item.highlights.map((point) => (
									<li>{point}</li>
								))}
							</ul>
						)}
					</div>
				</div>
			))
		}
	</div>
</section>

<style>
	.resume-section {
		margin-bottom: 0;
	}

	.resume-section :global(.section-eyebrow) {
		margin-bottom: 0.35rem;
	}

	.resume-section :global(.section-title) {
		margin-bottom: 2rem;
	}

	.timeline {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 1.75rem;
		padding-left: 1.75rem;
	}

	.timeline-line {
		position: absolute;
		left: 0.4rem;
		top: 0.5rem;
		bottom: 0.5rem;
		width: 2px;
		background: linear-gradient(180deg, var(--color-accent), var(--color-border));
		border-radius: 2px;
	}

	.timeline-item {
		position: relative;
		display: flex;
		gap: 1.25rem;
	}

	.timeline-marker {
		position: absolute;
		left: -1.75rem;
		top: 1.35rem;
		width: 1rem;
		height: 1rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.timeline-dot {
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 50%;
		background: var(--color-surface);
		border: 2px solid var(--color-accent);
		box-shadow: 0 0 0 4px var(--color-accent-soft);
	}

	.timeline-item.is-latest .timeline-dot {
		background: var(--color-accent);
		box-shadow: 0 0 0 4px var(--color-accent-glow);
	}

	.timeline-content {
		flex: 1;
		padding: 1.5rem;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.timeline-item.is-latest .timeline-content {
		border-color: color-mix(in srgb, var(--color-accent) 30%, var(--color-border));
		box-shadow: var(--shadow-md);
	}

	.timeline-content:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
	}

	.timeline-header {
		display: flex;
		justify-content: space-between;
		align-items: flex-start;
		gap: 1rem;
	}

	.item-primary {
		margin: 0;
		font-size: 1.1rem;
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.item-secondary {
		margin: 0.35rem 0 0;
		color: var(--color-accent);
		font-weight: 600;
		font-size: 0.95rem;
	}

	.item-period {
		padding: 0.3rem 0.75rem;
		border-radius: 999px;
		background: var(--color-accent-soft);
		color: var(--color-accent);
		font-size: 0.8rem;
		font-weight: 600;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.highlights {
		margin: 1.1rem 0 0;
		padding-left: 1.1rem;
		color: var(--color-text-muted);
	}

	.highlights li {
		margin-bottom: 0.45rem;
		line-height: 1.6;
	}

	.highlights li:last-child {
		margin-bottom: 0;
	}

	@media (max-width: 640px) {
		.timeline-header {
			flex-direction: column;
			gap: 0.75rem;
		}

		.item-period {
			align-self: flex-start;
		}
	}
</style>
