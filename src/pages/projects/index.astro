---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import ProjectFilter from '../../components/ProjectFilter.astro';
import { getCollection } from 'astro:content';
import { profile } from '../../data/resume';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={`${profile.name} · 作品集`} description="个人项目与作品展示">
	<Header variant="projects" />
	<main class="projects-page">
		<section class="page-hero">
			<div class="page-hero-bg" aria-hidden="true"></div>
			<div class="container page-hero-inner">
				<p class="section-eyebrow">Projects</p>
				<h1 class="page-title">作品集</h1>
				<p class="page-subtitle">我参与和独立完成的部分项目</p>
				<a href={base} class="back-link">← 返回首页</a>
			</div>
		</section>

		<section class="section">
			<div class="container reveal">
				<ProjectFilter />

				<div class="grid-2">
					{
						projects.map((project) => (
							<div data-project-category={project.data.category}>
								<ProjectCard project={project} />
							</div>
						))
					}
				</div>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>

<style>
	.projects-page {
		padding-bottom: 2rem;
	}

	.page-hero {
		position: relative;
		padding: 4rem 0 2.5rem;
		overflow: hidden;
	}

	.page-hero-bg {
		position: absolute;
		inset: 0;
		background:
			radial-gradient(ellipse 60% 80% at 80% 0%, var(--color-hero-glow-1), transparent),
			linear-gradient(180deg, var(--color-hero-top) 0%, var(--color-bg) 100%);
	}

	.page-hero-inner {
		position: relative;
		z-index: 1;
	}

	.page-title {
		margin: 0;
		font-size: clamp(2rem, 4vw, 2.5rem);
		font-weight: 700;
		letter-spacing: -0.04em;
	}

	.page-subtitle {
		margin: 0.75rem 0 0;
		color: var(--color-text-muted);
		font-size: 1.05rem;
	}

	.back-link {
		display: inline-block;
		margin-top: 1.25rem;
		font-size: 0.9rem;
		font-weight: 500;
		color: var(--color-text-muted);
	}

	.back-link:hover {
		color: var(--color-accent);
	}

	.page-hero .section-eyebrow {
		margin-bottom: 0.5rem;
	}
</style>
