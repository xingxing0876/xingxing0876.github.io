---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SkillTags from '../components/SkillTags.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ContactLinks from '../components/ContactLinks.astro';
import ResumeSection from '../components/ResumeSection.astro';
import { getCollection } from 'astro:content';
import { profile, experience, education, skills } from '../data/resume';

const base = import.meta.env.BASE_URL;
const allProjects = await getCollection('projects');
const featuredProjects = allProjects
	.filter((project) => project.data.featured)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const experienceItems = experience.map((item) => ({
	primary: item.company,
	secondary: item.role,
	period: item.period,
	highlights: item.highlights,
}));

const educationItems = education.map((item) => ({
	primary: item.school,
	secondary: item.degree,
	period: item.period,
}));
---

<BaseLayout title={`${profile.name} · ${profile.title}`} description={profile.summary}>
	<Header />
	<main>
		<Hero />

		<section class="section">
			<div class="container">
				<h2 class="section-title">个人简介</h2>
				<div class="prose">
					<p>{profile.summary}</p>
					<p>{profile.about}</p>
				</div>
			</div>
		</section>

		<section class="section section-alt">
			<div class="container">
				<ResumeSection title="工作经历" items={experienceItems} />
			</div>
		</section>

		<section class="section">
			<div class="container">
				<ResumeSection title="教育背景" items={educationItems} />
			</div>
		</section>

		<section class="section section-alt">
			<div class="container">
				<h2 class="section-title">技能</h2>
				<div class="skills-grid">
					<div>
						<h3 class="skill-group">核心技术</h3>
						<SkillTags skills={skills.core} />
					</div>
					<div>
						<h3 class="skill-group">中间件</h3>
						<SkillTags skills={skills.middleware} />
					</div>
					<div>
						<h3 class="skill-group">架构与工程</h3>
						<SkillTags skills={skills.architecture} />
					</div>
				</div>
			</div>
		</section>

		<section class="section">
			<div class="container">
				<h2 class="section-title">精选作品</h2>
				<p class="section-subtitle">近期完成的部分项目</p>
				<div class="grid-3">
					{featuredProjects.map((project) => <ProjectCard project={project} />)}
				</div>
				<div class="section-action">
					<a href={`${base}projects`} class="btn btn-outline">查看全部作品 →</a>
				</div>
			</div>
		</section>

		<section class="section section-alt">
			<div class="container contact-section">
				<h2 class="section-title">联系我</h2>
				<p class="section-subtitle">期待与你的交流与合作</p>
				<ContactLinks />
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>

<style>
	.section-alt {
		background: var(--color-surface);
		border-block: 1px solid var(--color-border);
	}

	.section-action {
		margin-top: 2rem;
		text-align: center;
	}

	.contact-section {
		text-align: center;
	}

	.contact-section :global(.contact-links) {
		justify-content: center;
	}

	.skills-grid {
		display: grid;
		gap: 1.5rem;
	}

	.skill-group {
		margin: 0 0 0.75rem;
		font-size: 0.95rem;
		color: var(--color-text-muted);
		font-weight: 600;
	}

	@media (min-width: 768px) {
		.skills-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
