---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import SkillTags from '../components/SkillTags.astro';
import ProjectCard from '../components/ProjectCard.astro';
import ContactLinks from '../components/ContactLinks.astro';
import ResumeSection from '../components/ResumeSection.astro';
import { getCollection } from 'astro:content';
import { profile, experience, skills } from '../data/resume';

const base = import.meta.env.BASE_URL;
const allProjects = await getCollection('projects');
const featuredProjects = allProjects
	.filter((project) => project.data.featured)
	.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const experienceItems = experience.map((item) => ({
	primary: item.company,
	secondary: item.role,
	period: item.period,
	highlights: item.highlights,
}));
---

<BaseLayout title={`${profile.name} · ${profile.title}`} description={profile.summary}>
	<Header variant="home" />
	<main data-page="home">
		<Hero projectCount={allProjects.length} />

		<section id="about" class="section reveal">
			<div class="container">
				<p class="section-eyebrow">About</p>
				<h2 class="section-title">个人简介</h2>
				<div class="prose intro-card card">
					<p>{profile.summary}</p>
					<p>{profile.about}</p>
				</div>
			</div>
		</section>

		<section id="experience" class="section section-alt reveal">
			<div class="container">
				<ResumeSection title="工作经历" eyebrow="Experience" items={experienceItems} />
			</div>
		</section>

		<section id="skills" class="section reveal">
			<div class="container">
				<p class="section-eyebrow">Skills</p>
				<h2 class="section-title">技能</h2>
				<div class="skills-grid">
					<div class="skill-card card">
						<h3 class="skill-group">核心技术</h3>
						<SkillTags skills={skills.core} />
					</div>
					<div class="skill-card card">
						<h3 class="skill-group">中间件</h3>
						<SkillTags skills={skills.middleware} />
					</div>
					<div class="skill-card card">
						<h3 class="skill-group">架构与工程</h3>
						<SkillTags skills={skills.architecture} />
					</div>
				</div>
			</div>
		</section>

		<section id="projects" class="section section-alt reveal">
			<div class="container">
				<p class="section-eyebrow">Projects</p>
				<h2 class="section-title">精选作品</h2>
				<p class="section-subtitle">近期完成的部分项目</p>
				<div class="grid-3">
					{featuredProjects.map((project) => <ProjectCard project={project} />)}
				</div>
				<div class="section-action">
					<a href={`${base}projects`} class="btn btn-outline">查看全部作品 →</a>
				</div>
			</div>
		</section>

		<section id="contact" class="section reveal">
			<div class="container contact-section">
				<div class="contact-card card">
					<p class="section-eyebrow">Contact</p>
					<h2 class="section-title">联系我</h2>
					<p class="section-subtitle">期待与你的交流与合作</p>
					<ContactLinks />
					<a href={`mailto:${profile.email}`} class="btn btn-primary contact-btn">发送邮件</a>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</BaseLayout>

<style>
	.section-alt {
		background: var(--color-surface);
		border-block: 1px solid var(--color-border);
	}

	.intro-card {
		padding: 2rem;
	}

	.skills-grid {
		display: grid;
		gap: 1.25rem;
	}

	.skill-card {
		padding: 1.5rem;
		transition: transform 0.2s, box-shadow 0.2s;
	}

	.skill-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-md);
	}

	.skill-group {
		margin: 0 0 1rem;
		font-size: 0.95rem;
		color: var(--color-text);
		font-weight: 700;
	}

	.section-action {
		margin-top: 2.5rem;
		text-align: center;
	}

	.contact-section {
		display: flex;
		justify-content: center;
	}

	.contact-card {
		width: min(100%, 560px);
		padding: 2.5rem 2rem;
		text-align: center;
		box-shadow: var(--shadow-md);
	}

	.contact-card .section-eyebrow {
		margin-bottom: 0.5rem;
	}

	.contact-card .section-title {
		margin-bottom: 0.5rem;
	}

	.contact-card .section-subtitle {
		margin-bottom: 1.5rem;
	}

	.contact-card :global(.contact-links) {
		justify-content: center;
		margin-bottom: 1.5rem;
	}

	.contact-btn {
		margin-top: 0.5rem;
	}

	@media (min-width: 768px) {
		.skills-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
